# ==================================================
# ECU Agent Configuration Example
# ==================================================
# Copy this file to .env and fill in your actual API keys

# ==================================================
# LLM Configuration - Chat Model Configuration
# ==================================================

# Provider Selection: auto, openai, qwen
# - auto: Automatic selection (prioritize OpenAI, fallback to Qwen)
# - openai: Force use OpenAI
# - qwen: Force use Qwen
LLM_PROVIDER=qwen

# OpenAI Configuration (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here

QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM & Embedding Models (e.g., qwen-plus, qwen-turbo)
LLM_MODEL=qwen-turbo
EMBEDDING_MODEL=text-embedding-v2

# ==================================================
# Embeddings Configuration - Embedding Model Configuration
# ==================================================

# Provider Selection: auto, openai, qwen
# - auto: Automatic selection (prioritize OpenAI, fallback to Qwen)
# - openai: Use OpenAI embeddings (recommended, vector stores created with this)
# - qwen: Use Qwen embeddings (requires rebuilding vector stores)
EMBEDDINGS_PROVIDER=qwen

# OpenAI Embeddings (if EMBEDDINGS_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Qwen Embeddings (if EMBEDDINGS_PROVIDER=qwen)
# Note: Qwen embeddings not fully compatible with LangChain OpenAIEmbeddings
# Requires custom implementation or rebuild vector stores
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================================================
# Langfuse Configuration - Observability Configuration
# ==================================================
LANGFUSE_SECRET_KEY=sk-your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=pk-your-langfuse-public-key-here
LANGFUSE_BASE_URL=https://langfuse.cccoder.top

# ==================================================
# Server Configuration - Server Configuration
# ==================================================
API_HOST=0.0.0.0
API_PORT=18500
API_RELOAD=false

# ==================================================
# Recommended Configuration Examples
# ==================================================

# Example 1: Pure Qwen (Recommended for China Deployment)
# LLM_PROVIDER=qwen
# EMBEDDINGS_PROVIDER=qwen
# QWEN_API_KEY=sk-your-qwen-key
# Benefits: 63% cost savings, no OpenAI access required

# Example 2: Hybrid Configuration (Cost Optimization)
# LLM_PROVIDER=qwen
# EMBEDDINGS_PROVIDER=openai
# QWEN_API_KEY=sk-your-qwen-key
# OPENAI_API_KEY=sk-your-openai-key
# Benefits: Lower LLM costs with Qwen, use existing OpenAI vector stores

# Example 3: Pure OpenAI (Simple but Higher Cost)
# LLM_PROVIDER=openai
# EMBEDDINGS_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# Benefits: Simple setup, well-tested
